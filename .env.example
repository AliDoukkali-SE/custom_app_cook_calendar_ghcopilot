# Azure Entra ID (Azure AD) settings — required for authentication
# Register an app in https://portal.azure.com -> Azure Active Directory -> App registrations
# Enable "Allow public client flows" on the Authentication blade (required for ROPC flow)

# Application (client) ID from your Azure app registration
AZURE_CLIENT_ID=your-client-id-here

# Directory (tenant) ID from your Azure app registration
AZURE_TENANT_ID=your-tenant-id-here

# Secret key used to sign session cookies — use a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Optional: Azure Table Storage connection string (for persistent meal storage)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
